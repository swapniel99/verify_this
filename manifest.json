{
  "manifest_version": 3,
  "name": "Verify This",
  "version": "1.0.0",
  "description": "Fact-check highlighted text using Gemini AI with grounding",
  "permissions": [
    "contextMenus",
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Verify This"
  }
}
